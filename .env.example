# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas
# Either provide the full connection string:
# DATABASE_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# NOTE: if local Node fails with "querySrv ECONNREFUSED" (a Windows DNS quirk),
# use the standard non-SRV connection string (mongodb://host1:27017,host2:27017,...)
# from Atlas -> Connect -> Drivers -> older driver versions.
# ...or the legacy user/pass pair (kept for backward compatibility):
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=matrimonyDB

# JWT (legacy name ACCESS_TOKEN is also supported)
JWT_ACCESS_SECRET=your_long_random_secret
JWT_EXPIRES_IN=1h

# Stripe (legacy name STIPE_PAYMENT_KEY is also supported)
# This project runs in TEST mode only — use an sk_test_ key.
# Live keys (sk_live_) are rejected unless ALLOW_LIVE_STRIPE=true is set.
STRIPE_SECRET_KEY=sk_test_xxx
# ALLOW_LIVE_STRIPE=false

# Firebase Admin (for POST /auth/firebase-login)
# Locally: path to the service-account JSON downloaded from
#   Firebase console -> Project settings -> Service accounts -> Generate new private key
# On Vercel: paste the raw JSON content instead (single line).
# FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json

# Comma-separated list of allowed origins. Leave unset to allow all (dev only).
# CORS_ORIGINS=http://localhost:5173,https://your-client.web.app
